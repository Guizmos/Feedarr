{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "System.Net.Http.HttpClient.TmdbClient": "Warning",
      "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
      "Microsoft.AspNetCore.Routing.EndpointMiddleware": "Warning",
      "Microsoft.Extensions.Http": "Warning"
    }
  },
  "App": {
    "SyncSourcesMaxConcurrency": 2,
    "HttpClients": {
      "AllowInvalidCertificates": false
    },
    "StorageUsageCacheTtlSeconds": 30,
    "SystemStatusCacheSeconds": 7,
    "PosterStatsRefreshSeconds": 60,
    "BadgesSseCoalesceMs": 750,
    "BadgesSummaryCacheSeconds": 3,
    "ThumbEnqueueTimeoutMs": 2000,
    "ThumbWorkers": 1,
    "MissingPosterSweepMinutes": 10,
    "MissingPosterSweepBatchSize": 200,
    "MissingPosterSweepShortCooldownMinutes": 15,
    "MissingPosterSweepHardFailCooldownMinutes": 1440,
    "Http": {
      "Arr": {
        "MinimumThroughput": 5,
        "BreakDurationSeconds": 30
      },
      "Providers": {
        "MinimumThroughput": 10,
        "BreakDurationSeconds": 60
      },
      "Indexers": {
        "MinimumThroughput": 5,
        "BreakDurationSeconds": 30
      }
    },
    "Updates": {
      "Enabled": true,
      "RepoOwner": "Guizmos",
      "RepoName": "Feedarr",
      "CheckIntervalHours": 6,
      "TimeoutSeconds": 10,
      "AllowPrerelease": false,
      "GitHubApiBaseUrl": "https://api.github.com",
      "GitHubToken": ""
    }
  },
  "Security": {
    "RequireHttpsForBasicAuth": true,
    "TrustedReverseProxyTls": false,
    "KnownProxies": [],
    "KnownNetworks": [],
    "AllowedOrigins": [
      "http://localhost:5173"
    ],
    "RequireXsrfHeaderForUnsafeMethods": true,
    "AuthThrottle": {
      "WindowSeconds": 300,
      "SoftBlockThreshold": 5,
      "MediumBlockThreshold": 10,
      "HardBlockThreshold": 20,
      "SoftBlockSeconds": 5,
      "MediumBlockSeconds": 30,
      "HardBlockSeconds": 300
    }
  },
  "PosterFetch": {
    "MaxAttempts": 3,
    "RequestTimeoutSeconds": 60,
    "RefreshTtlDays": 30,
    "MinIntervalMs": 250,
    "MaxItemDurationSeconds": 60,
    "RetryDelaysSeconds": [ 2, 5, 15 ]
  },
  "AllowedHosts": "*"
}
